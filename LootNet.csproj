  <Target Name="PostBuild" AfterTargets="PostBuildEvent">
    <MakeDir Directories="D:\SPT dev\BepInEx\plugins\LootNet" />
    <Copy SourceFiles="$(TargetPath)"
          DestinationFolder="D:\SPT dev\BepInEx\plugins\LootNet"
          SkipUnchangedFiles="false"
          UseHardlinksIfPossible="false"
          Retries="3"
          RetryDelayMilliseconds="500" />
  </Target>

  <Target Name="PackageModForDistribution" AfterTargets="Build">
    <PropertyGroup>
      <ModName>$(AssemblyName)</ModName>
      <ZipFileName>$(ModName).zip</ZipFileName>
      <TempPackageDir>$(ProjectDir)obj\Package</TempPackageDir>
      <ClientPackageDir>$(TempPackageDir)\BepInEx\plugins\LootNet</ClientPackageDir>
      <ServerPackageDir>$(TempPackageDir)\SPT\user\mods\LootNetServer</ServerPackageDir>
      <ServerProjectPath>$(ProjectDir)server\LootNetServer.csproj</ServerProjectPath>
      <ServerOutputDir>$(ProjectDir)server\bin\Release</ServerOutputDir>
    </PropertyGroup>
    <Message Text="--- Building server mod ---" Importance="high" />
    <Exec Command="dotnet build &quot;$(ServerProjectPath)&quot; -c Release --nologo -v q"
          IgnoreExitCode="true" />
    <PropertyGroup>
      <ServerDllExists Condition="Exists('$(ServerOutputDir)\LootNetServer.dll')">true</ServerDllExists>
    </PropertyGroup>
    <Message Text="--- Starting Mod packaging for distribution ---" Importance="high" />
    <RemoveDir Directories="$(TempPackageDir)" />
    <MakeDir Directories="$(ClientPackageDir)" />
    <MakeDir Directories="$(ServerPackageDir)" Condition="'$(ServerDllExists)' == 'true'" />
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(ClientPackageDir)" />
    <Copy SourceFiles="$(ProjectDir)Resources\weii weii.mp4" DestinationFolder="$(ClientPackageDir)" Condition="Exists('$(ProjectDir)Resources\weii weii.mp4')" />
    <Copy SourceFiles="$(ServerOutputDir)\LootNetServer.dll" DestinationFolder="$(ServerPackageDir)" Condition="'$(ServerDllExists)' == 'true'" />
    <ZipDirectory SourceDirectory="$(TempPackageDir)" DestinationFile="$(ProjectDir)$(ZipFileName)" Overwrite="true" />
    <RemoveDir Directories="$(TempPackageDir)" />
    <Message Text="--- Mod successfully packaged at: $(ProjectDir)$(ZipFileName) ---" Importance="high" />
  </Target>

</Project>

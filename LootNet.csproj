<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <AssemblyName>LootNet</AssemblyName>
    <RootNamespace>LootNet</RootNamespace>
    <Nullable>disable</Nullable>
    <Authors>user</Authors>
    <AssemblyVersion>1.0.0</AssemblyVersion>
    <FileVersion>$(AssemblyVersion)</FileVersion>
    <Configurations>Debug;Release</Configurations>
    <Version>$(AssemblyVersion)</Version>
    <LangVersion>latest</LangVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>true</Deterministic>
  </PropertyGroup>

  <!-- Exclude reference repos and the server subfolder from compilation -->
  <ItemGroup>
    <Compile Remove="original mod\**" />
    <EmbeddedResource Remove="original mod\**" />
    <None Remove="original mod\**" />
    <Compile Remove="server\**" />
    <EmbeddedResource Remove="server\**" />
    <None Remove="server\**" />
    <Compile Remove="SPT-PitFireTeam\**" />
    <EmbeddedResource Remove="SPT-PitFireTeam\**" />
    <None Remove="SPT-PitFireTeam\**" />
  </ItemGroup>

